<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Primary Brand Color -->
    <Color x:Key="PrimaryColor">#5957D6</Color>

    <!-- Light Mode Colors -->
    <Color x:Key="BackgroundLight">#FFFFFF</Color>
    <Color x:Key="BackgroundLightSecondary">#F5F5F7</Color>
    <Color x:Key="BackgroundLightTertiary">#EFEFEF</Color>
    <Color x:Key="TextLightPrimary">#000000</Color>
    <Color x:Key="TextLightSecondary">#65676B</Color>
    <Color x:Key="TextLightTertiary">#999999</Color>
    <Color x:Key="BorderLight">#D2D2D7</Color>
    <Color x:Key="DividerLight">#E5E5EA</Color>

    <!-- Dark Mode Colors -->
    <Color x:Key="BackgroundDark">#1D1D1F</Color>
    <Color x:Key="BackgroundDarkSecondary">#424245</Color>
    <Color x:Key="BackgroundDarkTertiary">#5A5A5E</Color>
    <Color x:Key="TextDarkPrimary">#FFFFFF</Color>
    <Color x:Key="TextDarkSecondary">#A1A1A6</Color>
    <Color x:Key="TextDarkTertiary">#66666D</Color>
    <Color x:Key="BorderDark">#424245</Color>
    <Color x:Key="DividerDark">#2C2C2E</Color>

    <!-- Status Colors -->
    <Color x:Key="SuccessLight">#34C759</Color>
    <Color x:Key="SuccessDark">#32AE5E</Color>
    <Color x:Key="WarningLight">#FF9500</Color>
    <Color x:Key="WarningDark">#FF9500</Color>
    <Color x:Key="DangerLight">#FF3B30</Color>
    <Color x:Key="DangerDark">#FF453A</Color>
    <Color x:Key="InfoLight">#0071E3</Color>
    <Color x:Key="InfoDark">#0A84FF</Color>
    
    <!-- Primary Brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />

    <!-- Light Mode Brushes -->
    <SolidColorBrush x:Key="BackgroundBrushLight" Color="{StaticResource BackgroundLight}" />
    <SolidColorBrush x:Key="BackgroundBrushLightSecondary" Color="{StaticResource BackgroundLightSecondary}" />
    <SolidColorBrush x:Key="BackgroundBrushLightTertiary" Color="{StaticResource BackgroundLightTertiary}" />
    <SolidColorBrush x:Key="TextBrushLightPrimary" Color="{StaticResource TextLightPrimary}" />
    <SolidColorBrush x:Key="TextBrushLightSecondary" Color="{StaticResource TextLightSecondary}" />
    <SolidColorBrush x:Key="TextBrushLightTertiary" Color="{StaticResource TextLightTertiary}" />
    <SolidColorBrush x:Key="BorderBrushLight" Color="{StaticResource BorderLight}" />
    <SolidColorBrush x:Key="DividerBrushLight" Color="{StaticResource DividerLight}" />

    <!-- Dark Mode Brushes -->
    <SolidColorBrush x:Key="BackgroundBrushDark" Color="{StaticResource BackgroundDark}" />
    <SolidColorBrush x:Key="BackgroundBrushDarkSecondary" Color="{StaticResource BackgroundDarkSecondary}" />
    <SolidColorBrush x:Key="BackgroundBrushDarkTertiary" Color="{StaticResource BackgroundDarkTertiary}" />
    <SolidColorBrush x:Key="TextBrushDarkPrimary" Color="{StaticResource TextDarkPrimary}" />
    <SolidColorBrush x:Key="TextBrushDarkSecondary" Color="{StaticResource TextDarkSecondary}" />
    <SolidColorBrush x:Key="TextBrushDarkTertiary" Color="{StaticResource TextDarkTertiary}" />
    <SolidColorBrush x:Key="BorderBrushDark" Color="{StaticResource BorderDark}" />
    <SolidColorBrush x:Key="DividerBrushDark" Color="{StaticResource DividerDark}" />

    <!-- Status Brushes -->
    <SolidColorBrush x:Key="SuccessBrushLight" Color="{StaticResource SuccessLight}" />
    <SolidColorBrush x:Key="SuccessBrushDark" Color="{StaticResource SuccessDark}" />
    <SolidColorBrush x:Key="WarningBrushLight" Color="{StaticResource WarningLight}" />
    <SolidColorBrush x:Key="WarningBrushDark" Color="{StaticResource WarningDark}" />
    <SolidColorBrush x:Key="DangerBrushLight" Color="{StaticResource DangerLight}" />
    <SolidColorBrush x:Key="DangerBrushDark" Color="{StaticResource DangerDark}" />
    <SolidColorBrush x:Key="InfoBrushLight" Color="{StaticResource InfoLight}" />
    <SolidColorBrush x:Key="InfoBrushDark" Color="{StaticResource InfoDark}" />

</ResourceDictionary>
