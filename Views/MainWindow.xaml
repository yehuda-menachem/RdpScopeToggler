<Window x:Class="RdpScopeToggler.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:views="clr-namespace:RdpScopeToggler.Views"
        WindowStartupLocation="CenterScreen"

        FontFamily="Segoe UI"

        prism:ViewModelLocator.AutoWireViewModel="True"

        Title="{Binding Title}"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        ResizeMode="CanResize"
        WindowState="Maximized"

        Icon="pack://siteoforigin:,,,/Assets/remote-desktop.ico"

        Background="{DynamicResource BackgroundBrushLight}"
        Foreground="{DynamicResource TextBrushLightPrimary}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        Loaded="MainWindow_Loaded"
        >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Sidebar Navigation -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Grid.Row="0"
                Background="{DynamicResource CardBackground}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource BorderBrushLight}"
                Padding="24"
                IsEnabled="False"
                Visibility="Collapsed">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Border Width="40" Height="40" CornerRadius="8" Background="{DynamicResource PrimaryBrush}">
                            <TextBlock Text="&#xE8AF;" FontFamily="Segoe MDL2 Assets" FontSize="18"
                                       Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="RdpScope" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Desktop Manager" FontSize="11" Foreground="{DynamicResource TextBrushLightSecondary}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1">
                    <Button x:Name="NavHome" Style="{StaticResource NavItemButtonActive}" Margin="0,0,0,8" Click="OnHomeClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Home" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavAccessControl" Style="{StaticResource NavItemButton}" Margin="0,0,0,8" Click="OnAccessControlClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE83D;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Access Control" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavWhitelist" Style="{StaticResource NavItemButton}" Margin="0,0,0,8" Click="OnWhitelistClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8A6;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Whitelist" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavLocalAddresses" Style="{StaticResource NavItemButton}" Margin="0,0,0,8" Click="OnLocalAddressesClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8F7;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Local Addresses" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="NavSettings" Style="{StaticResource NavItemButton}" Margin="0,32,0,0" Click="OnSettingsClick">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       VerticalAlignment="Center" Margin="0,0,10,0" />
                            <TextBlock Text="Settings" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- System Version (Footer) -->
                <Border Grid.Row="2" Background="{DynamicResource ContentAreaBackground}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                        CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="SYSTEM VERSION" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="v2.4.0 (Stable)" FontSize="14" FontWeight="500" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Grid.Row="0" Background="{DynamicResource BackgroundBrushLight}">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border x:Name="HeaderBorder" Grid.Row="0" Background="{DynamicResource CardBackground}"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrushLight}"
                    Padding="32,0,32,0"
                    Visibility="Collapsed">
                <Grid>
                    <TextBlock x:Name="PageTitle" Text="Home" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="LogoutButton" Style="{StaticResource IconButton}" Margin="0,0,16,0" Click="OnLogoutClick">
                            <TextBlock Text="&#xEA8F;" FontFamily="Segoe MDL2 Assets" FontSize="16" />
                        </Button>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                       Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,8,0"
                                       VerticalAlignment="Center" />
                            <TextBlock x:Name="CurrentUsername" Text="Admin Account" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{DynamicResource TextBrushLightPrimary}" VerticalAlignment="Center" />
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="32">
                <ContentControl prism:RegionManager.RegionName="ContentRegion" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>
