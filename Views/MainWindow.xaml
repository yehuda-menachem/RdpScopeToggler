<Window x:Class="RdpScopeToggler.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:prism="http://prismlibrary.com/"
        xmlns:views="clr-namespace:RdpScopeToggler.Views"
        WindowStartupLocation="CenterScreen"

        FontFamily="Segoe UI"

        prism:ViewModelLocator.AutoWireViewModel="True"

        Title="{Binding Title}"
        Height="800" Width="1200"
        MinHeight="600" MinWidth="900"
        ResizeMode="CanResize"

        Icon="pack://siteoforigin:,,,/Assets/remote-desktop.ico"

        Background="{DynamicResource BackgroundBrushLight}"
        Foreground="{DynamicResource TextBrushLightPrimary}"
        SnapsToDevicePixels="True"
        UseLayoutRounding="True"
        >

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="256" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Sidebar Navigation -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{DynamicResource BackgroundBrushLightSecondary}"
                BorderThickness="0,0,1,0"
                BorderBrush="{DynamicResource BorderBrushLight}"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo -->
                <StackPanel Grid.Row="0" Margin="0,0,0,32">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Rectangle Width="40" Height="40" Fill="{DynamicResource PrimaryBrush}"
                                   RadiusX="8" RadiusY="8" />
                        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
                            <TextBlock Text="RdpScope" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Desktop Manager" FontSize="11" Foreground="{DynamicResource TextBrushLightSecondary}" />
                        </StackPanel>
                    </StackPanel>
                </StackPanel>

                <!-- Navigation Items -->
                <StackPanel Grid.Row="1">
                    <Button Content="Home" Style="{StaticResource NavItemButton}" Margin="0,0,0,8" />
                    <Button Content="Access Control" Style="{StaticResource NavItemButton}" Margin="0,0,0,8" />
                    <Button Content="Whitelist" Style="{StaticResource NavItemButton}" Margin="0,0,0,8" />
                    <Button Content="Local Addresses" Style="{StaticResource NavItemButton}" Margin="0,0,0,8" />
                    <Button Content="Settings" Style="{StaticResource NavItemButton}" Margin="0,32,0,0" />
                </StackPanel>

                <!-- System Version (Footer) -->
                <Border Grid.Row="2" Background="{DynamicResource BackgroundBrushLight}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                        CornerRadius="12" Padding="16">
                    <StackPanel>
                        <TextBlock Text="System Version" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource PrimaryBrush}" />
                        <TextBlock Text="v2.4.0 (Stable)" FontSize="14" FontWeight="500" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Column="1" Grid.Row="0" Background="{DynamicResource BackgroundBrushLight}">
            <Grid.RowDefinitions>
                <RowDefinition Height="64" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0" Background="{DynamicResource BackgroundBrushLight}"
                    BorderThickness="0,0,0,1" BorderBrush="{DynamicResource BorderBrushLight}"
                    Padding="32,0,32,0">
                <Grid>
                    <TextBlock Text="Home" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" />
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="🔔" Style="{StaticResource IconButton}" Margin="0,0,16,0" />
                        <Button Content="❓" Style="{StaticResource IconButton}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Content -->
            <ScrollViewer Grid.Row="1" Padding="32">
                <ContentControl prism:RegionManager.RegionName="ContentRegion" />
            </ScrollViewer>
        </Grid>
    </Grid>
</Window>

