<UserControl x:Class="RdpScopeToggler.Views.LocalAddressesUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:converter="clr-namespace:RdpScopeToggler.Converters"
             xmlns:prism="http://prismlibrary.com/"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <converter:InverseBooleanToVisibilityConverter x:Key="InverseBooleanToVisibilityConverter"/>
        <converter:InverseBooleanConverter x:Key="InverseBooleanConverter"/>
        <converter:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ContentAreaBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Margin="32">

                <!-- Header -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Local Addresses" FontSize="28" FontWeight="ExtraBold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                    <TextBlock Text="Manage and discover computers on your local network." FontSize="14" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Network Discovery Card -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                        CornerRadius="12" Padding="24" Margin="0,0,0,32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Section Header -->
                        <TextBlock Grid.Row="0" Text="Network Scan" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,0,0,16" />

                        <!-- Scan Button & Status -->
                        <StackPanel Grid.Row="1" Orientation="Vertical">
                            <Button Content="🔍 Scan for Local Addresses" Command="{Binding LoadLocalDevicesCommand}"
                                    Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                    Padding="16,12" FontWeight="SemiBold"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />

                            <!-- Loading State -->
                            <StackPanel Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"
                                       HorizontalAlignment="Center" Margin="0,12,0,0">
                                <ProgressBar Width="200" Height="6" IsIndeterminate="True" Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,12" />
                                <TextBlock Text="Scanning network..." HorizontalAlignment="Center"
                                          Foreground="{DynamicResource TextBrushLightSecondary}" FontSize="12" />
                            </StackPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Addresses List Card -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                        CornerRadius="12" Padding="24"
                        Visibility="{Binding IsLoading, Converter={StaticResource InverseBooleanToVisibilityConverter}}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Section Header -->
                        <TextBlock Grid.Row="0" Text="Discovered Computers" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,0,0,16" />

                        <!-- List -->
                        <ScrollViewer Grid.Row="1" MaxHeight="300" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding AlwaysOnListItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundBrushLight}"
                                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Delete Button -->
                                                <Button Grid.Column="0"
                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Width="36" Height="36" Padding="0"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Foreground="#FF3B30"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="18">
                                                    <TextBlock Text="✕" FontWeight="Bold" />
                                                </Button>

                                                <!-- Name & Address -->
                                                <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrushLightPrimary}" />
                                                    <TextBlock Text="{Binding Address}" FontSize="12"
                                                               Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,4,0,0" />
                                                </StackPanel>

                                                <!-- Status Badge -->
                                                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="6" Padding="12,6"
                                                        VerticalAlignment="Center" Margin="0,0,16,0">
                                                    <TextBlock Text="Active" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#34C759" />
                                                </Border>

                                                <!-- Toggle -->
                                                <CheckBox Grid.Column="3" VerticalAlignment="Center"
                                                         IsChecked="{Binding IsOpen, Mode=TwoWay}" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal">
                            <Button Content="+ Add Address" Command="{Binding AddItemCommand}"
                                    Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                    Padding="16,12" FontWeight="SemiBold"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" Margin="0,0,12,0" />
                            <Button Content="Save Changes" Command="{Binding SaveCommand}"
                                    Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                    Padding="16,12" FontWeight="SemiBold"
                                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBooleanConverter}}" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
