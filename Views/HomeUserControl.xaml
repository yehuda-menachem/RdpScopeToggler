<UserControl x:Class="RdpScopeToggler.Views.HomeUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:converter="clr-namespace:RdpScopeToggler.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <UserControl.Resources>
        <converter:EnumToBoolConverter x:Key="EnumToBoolConverter" />
        <converter:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Grid Background="{DynamicResource BackgroundBrushLight}">
            <StackPanel Margin="0">

                <!-- Status Overview Section -->
                <StackPanel Margin="0,0,0,24">
                    <TextBlock Text="Status Overview" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource TextBrushLightPrimary}" />

                    <!-- 4 Status Cards Grid -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Whitelist Active Card -->
                        <Border Grid.Column="0" Margin="0,0,12,0"
                                Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="40" Height="40" CornerRadius="8" Background="#34C759" Padding="8">
                                        <TextBlock Text="✓" Foreground="White" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="LIVE" FontSize="10" FontWeight="Bold" Margin="8,0,0,0" Foreground="#34C759" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Whitelist Active" FontSize="13" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,0,4" />
                                <TextBlock Text="Active" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                            </StackPanel>
                        </Border>

                        <!-- All Access Disabled Card -->
                        <Border Grid.Column="1" Margin="12,0,12,0"
                                Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="40" Height="40" CornerRadius="8" Background="#FF3B30" Padding="8">
                                        <TextBlock Text="✗" Foreground="White" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="SECURE" FontSize="10" FontWeight="Bold" Margin="8,0,0,0" Foreground="#FF3B30" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="All Access Disabled" FontSize="13" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,0,4" />
                                <TextBlock Text="Disabled" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                            </StackPanel>
                        </Border>

                        <!-- Time-based Access Card -->
                        <Border Grid.Column="2" Margin="12,0,12,0"
                                Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="40" Height="40" CornerRadius="8" Background="#FF9500" Padding="8">
                                        <TextBlock Text="⏰" Foreground="White" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="ACTIVE" FontSize="10" FontWeight="Bold" Margin="8,0,0,0" Foreground="#FF9500" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Time-based Access" FontSize="13" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,0,4" />
                                <TextBlock Text="Scheduled" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                            </StackPanel>
                        </Border>

                        <!-- Local Access Active Card -->
                        <Border Grid.Column="3" Margin="12,0,0,0"
                                Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                    <Border Width="40" Height="40" CornerRadius="8" Background="#34C759" Padding="8">
                                        <TextBlock Text="✓" Foreground="White" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                    <TextBlock Text="LOCAL" FontSize="10" FontWeight="Bold" Margin="8,0,0,0" Foreground="#34C759" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Local Access Active" FontSize="13" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,0,4" />
                                <TextBlock Text="Active" FontSize="22" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Quick Actions Section -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Quick Actions" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" Foreground="{DynamicResource TextBrushLightPrimary}" />

                    <!-- 3 Column Grid for Action Cards -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Schedule Access Card -->
                        <Border Grid.Column="0" Margin="0,0,16,0"
                                Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <!-- Header with icon -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="📅" FontSize="18" Margin="0,0,8,0" />
                                    <TextBlock Text="Schedule Access" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Date Input -->
                                <TextBlock Text="Date" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,0,4" />
                                <DatePicker SelectedDate="{Binding SelectedDate, Mode=TwoWay}"
                                            Background="{DynamicResource BackgroundBrushLight}"
                                            Foreground="{DynamicResource TextBrushLightPrimary}"
                                            Padding="8" Margin="0,0,0,12"
                                            Height="36" VerticalContentAlignment="Center" />

                                <!-- Time Range Input -->
                                <TextBlock Text="Time Range" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,0,4" />
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBox Grid.Column="0" Text="" Background="{DynamicResource BackgroundBrushLight}"
                                             Foreground="{DynamicResource TextBrushLightPrimary}" Padding="8" Height="36" VerticalContentAlignment="Center" />
                                    <TextBox Grid.Column="2" Text="" Background="{DynamicResource BackgroundBrushLight}"
                                             Foreground="{DynamicResource TextBrushLightPrimary}" Padding="8" Height="36" VerticalContentAlignment="Center" />
                                </Grid>

                                <!-- Set Schedule Button -->
                                <Button Content="Set Schedule" Style="{StaticResource PrimaryButton}" Margin="0,12,0,0" Height="44" />
                            </StackPanel>
                        </Border>

                        <!-- Access Mode Card -->
                        <Border Grid.Column="1" Margin="16,0,16,0"
                                Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <!-- Header with icon -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="🔄" FontSize="18" Margin="0,0,8,0" />
                                    <TextBlock Text="Access Mode" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- Security Level Dropdown -->
                                <TextBlock Text="Security Level" FontSize="11" FontWeight="SemiBold" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,0,0,4" />
                                <ComboBox Background="{DynamicResource BackgroundBrushLight}"
                                          Foreground="{DynamicResource TextBrushLightPrimary}"
                                          Padding="8" Margin="0,0,0,12" Height="36" VerticalContentAlignment="Center">
                                    <ComboBoxItem>High Strictness (Whitelist Only)</ComboBoxItem>
                                    <ComboBoxItem>Standard (Scheduled + Local)</ComboBoxItem>
                                    <ComboBoxItem>Development (All Local Open)</ComboBoxItem>
                                    <ComboBoxItem>Emergency Lockdown</ComboBoxItem>
                                </ComboBox>

                                <!-- Info Box -->
                                <Border Background="{DynamicResource PrimaryBrush}" BorderThickness="0" CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <TextBlock Text="Current mode restricts all connections except those explicitly listed in the Whitelist tab."
                                               FontSize="12" Foreground="White" TextWrapping="Wrap" />
                                </Border>

                                <!-- Apply Settings Button -->
                                <Button Content="Apply Settings" Style="{StaticResource SecondaryButton}" />
                            </StackPanel>
                        </Border>

                        <!-- Rapid Controls Card -->
                        <Border Grid.Column="2" Margin="16,0,0,0"
                                Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="12" Padding="16">
                            <StackPanel>
                                <!-- Header with icon -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                    <TextBlock Text="⚡" FontSize="18" Margin="0,0,8,0" />
                                    <TextBlock Text="Rapid Controls" FontSize="14" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" VerticalAlignment="Center" />
                                </StackPanel>

                                <!-- 2x2 Button Grid -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="8" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <!-- Open All Button -->
                                    <Button Grid.Row="0" Grid.Column="0" Content="🔓 Open All" Padding="12,8" Background="#34C759" Foreground="White" FontWeight="Bold" />

                                    <!-- Close All Button -->
                                    <Button Grid.Row="0" Grid.Column="2" Content="🔒 Close All" Padding="12,8" Background="#FF3B30" Foreground="White" FontWeight="Bold" />

                                    <!-- Enable All Button -->
                                    <Button Grid.Row="2" Grid.Column="0" Content="✓ Enable All" Padding="12,8" Background="{DynamicResource PrimaryBrush}" Foreground="White" FontWeight="Bold" />

                                    <!-- Disable All Button -->
                                    <Button Grid.Row="2" Grid.Column="2" Content="✗ Disable All" Padding="12,8" Background="{DynamicResource TextBrushLightSecondary}" Foreground="White" FontWeight="Bold" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Info Banner Section -->
                <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="32" Margin="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" VerticalAlignment="Center">
                            <TextBlock Text="Secure Remote Access" FontSize="24" FontWeight="Bold" Foreground="White" Margin="0,0,0,8" />
                            <TextBlock Text="Monitor and control your desktop connectivity from a single dashboard. Your rules are processed at the hardware level for maximum security."
                                       FontSize="14" Foreground="White" TextWrapping="Wrap" Margin="0,0,0,16" />
                            <StackPanel Orientation="Horizontal">
                                <Button Content="View Detailed Logs" Background="White" Foreground="{DynamicResource PrimaryBrush}" Padding="16,8" Margin="0,0,12,0" FontWeight="Bold" />
                                <Button Content="Quick Setup Wizard" Background="Transparent" Foreground="White" Padding="16,8" BorderThickness="1" BorderBrush="White" FontWeight="Bold" />
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" Width="160" Height="160" CornerRadius="80" Background="White" Opacity="0.2" Margin="32,0,0,0" VerticalAlignment="Center" HorizontalAlignment="Right" />
                    </Grid>
                </Border>
            </StackPanel>
        </Grid>
    </ScrollViewer>

</UserControl>
