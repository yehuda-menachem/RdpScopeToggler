<UserControl x:Class="RdpScopeToggler.Views.WhiteListUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             xmlns:converters="clr-namespace:RdpScopeToggler.Converters"
             prism:ViewModelLocator.AutoWireViewModel="True"
             d:DesignHeight="600" d:DesignWidth="800">
    <UserControl.Resources>
        <converters:StringNullOrEmptyToVisibilityConverter x:Key="StringNullOrEmptyToVisibilityConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource ContentAreaBackground}">
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Margin="32">

                <!-- Header -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Whitelisted Addresses" FontSize="28" FontWeight="ExtraBold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                    <TextBlock Text="Manage approved remote access addresses." FontSize="14" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Address List Card -->
                <Border Background="{DynamicResource CardBackground}"
                        BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                        CornerRadius="12" Padding="24" Margin="0,0,0,32">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!-- Section Header -->
                        <TextBlock Grid.Row="0" Text="Whitelisted Addresses" FontSize="16" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,0,0,16" />

                        <!-- List -->
                        <ScrollViewer Grid.Row="1" MaxHeight="400" VerticalScrollBarVisibility="Auto" Margin="0,0,0,16">
                            <ItemsControl ItemsSource="{Binding WhiteListItems}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource BackgroundBrushLight}"
                                                CornerRadius="8" Padding="16" Margin="0,0,0,12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Delete Button -->
                                                <Button Grid.Column="0"
                                                        Command="{Binding DataContext.RemoveItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        Width="36" Height="36" Padding="0"
                                                        VerticalAlignment="Center" HorizontalAlignment="Center"
                                                        Foreground="#FF3B30"
                                                        Background="Transparent"
                                                        BorderThickness="0"
                                                        FontSize="18">
                                                    <TextBlock Text="✕" FontWeight="Bold" />
                                                </Button>

                                                <!-- Address & Name -->
                                                <StackPanel Grid.Column="1" Margin="16,0" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource TextBrushLightPrimary}" />
                                                    <TextBlock Text="{Binding Address}" FontSize="12"
                                                               Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,4,0,0" />
                                                </StackPanel>

                                                <!-- Status -->
                                                <Border Grid.Column="2" Background="#E8F5E9" CornerRadius="6" Padding="12,6"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="Active" FontSize="12" FontWeight="SemiBold"
                                                               Foreground="#34C759" />
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <!-- Action Buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,0">
                            <Button Content="+ Add Address" Command="{Binding AddItemCommand}"
                                    Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                    Padding="16,12" FontWeight="SemiBold" Margin="0,0,12,0" />
                            <Button Content="Save Changes" Command="{Binding SaveCommand}"
                                    Background="{DynamicResource PrimaryBrush}" Foreground="White"
                                    Padding="16,12" FontWeight="SemiBold" />
                        </StackPanel>
                    </Grid>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>

</UserControl>
