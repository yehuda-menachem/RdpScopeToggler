<UserControl x:Class="RdpScopeToggler.Views.SettingsUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             mc:Ignorable="d"
             prism:ViewModelLocator.AutoWireViewModel="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <Border Background="{DynamicResource BackgroundBrushLight}" Padding="32">
            <StackPanel Margin="0">

                <!-- Preferences Header -->
                <StackPanel Margin="0,0,0,32">
                    <TextBlock Text="Preferences" FontSize="28" FontWeight="ExtraBold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                    <TextBlock Text="Manage your application preferences and appearance." FontSize="14" Foreground="{DynamicResource TextBrushLightSecondary}" Margin="0,4,0,0" />
                </StackPanel>

                <!-- Settings Cards -->
                <StackPanel Margin="0,0,0,32">

                    <!-- Language Card -->
                    <Border Background="{DynamicResource BackgroundBrushLightSecondary}"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="48" Height="48" CornerRadius="8" Background="{DynamicResource PrimaryBrush}" Padding="12">
                                    <TextBlock Text="🌐" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Language" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                                    <TextBlock Text="Choose your preferred language" FontSize="12" Foreground="{DynamicResource TextBrushLightSecondary}" />
                                </StackPanel>
                            </StackPanel>

                            <ComboBox Grid.Column="2" SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                                      ItemsSource="{Binding LanguagesOptions}"
                                      Background="{DynamicResource BackgroundBrushLight}"
                                      Foreground="{DynamicResource TextBrushLightPrimary}"
                                      BorderBrush="{DynamicResource BorderBrushLight}"
                                      Padding="8" MinWidth="120" Height="36"
                                      VerticalContentAlignment="Center">
                                <ComboBoxItem>English</ComboBoxItem>
                                <ComboBoxItem>עברית</ComboBoxItem>
                            </ComboBox>
                        </Grid>
                    </Border>

                    <!-- Theme Card -->
                    <Border Background="{DynamicResource BackgroundBrushLightSecondary}"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="48" Height="48" CornerRadius="8" Background="{DynamicResource PrimaryBrush}" Padding="12">
                                    <TextBlock Text="🎨" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Theme" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                                    <TextBlock Text="Choose appearance" FontSize="12" Foreground="{DynamicResource TextBrushLightSecondary}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Theme Toggle Buttons -->
                            <Border Grid.Column="2" Background="{DynamicResource BackgroundBrushLight}" CornerRadius="8" Padding="2">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="☀️ Light" Padding="16,8" Background="White" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                                    <Button Content="🌙 Dark" Padding="16,8" Foreground="{DynamicResource TextBrushLightSecondary}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- Default State Card -->
                    <Border Background="{DynamicResource BackgroundBrushLightSecondary}"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                <Border Width="48" Height="48" CornerRadius="8" Background="{DynamicResource PrimaryBrush}" Padding="12">
                                    <TextBlock Text="⚡" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="Default State" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                                    <TextBlock Text="On application startup" FontSize="12" Foreground="{DynamicResource TextBrushLightSecondary}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- Default State Toggle Buttons -->
                            <Border Grid.Column="2" Background="{DynamicResource BackgroundBrushLight}" CornerRadius="8" Padding="2">
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Enabled" Padding="16,8" Background="White" Foreground="{DynamicResource PrimaryBrush}" FontWeight="SemiBold" />
                                    <Button Content="Disabled" Padding="16,8" Foreground="{DynamicResource TextBrushLightSecondary}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- About Card -->
                    <Border Background="{DynamicResource BackgroundBrushLightSecondary}"
                            BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                            CornerRadius="12" Padding="16" Margin="0,0,0,16">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
                                <Border Width="48" Height="48" CornerRadius="8" Background="{DynamicResource PrimaryBrush}" Padding="12">
                                    <TextBlock Text="ℹ️" FontSize="20" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="16,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="About" FontSize="15" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" />
                                    <TextBlock Text="Application information" FontSize="12" Foreground="{DynamicResource TextBrushLightSecondary}" />
                                </StackPanel>
                            </StackPanel>

                            <!-- About Info Grid -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Background="{DynamicResource BackgroundBrushLight}" CornerRadius="8" Padding="12" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="VERSION" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightSecondary}" />
                                        <TextBlock Text="2.0.0" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>

                                <Border Grid.Column="1" Background="{DynamicResource BackgroundBrushLight}" CornerRadius="8" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="LICENSE" FontSize="10" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightSecondary}" />
                                        <TextBlock Text="MIT" FontSize="18" FontWeight="Bold" Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Support Card -->
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="12" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                <TextBlock Text="💬 Need help?" FontSize="15" FontWeight="Bold" Foreground="White" />
                                <TextBlock Text="Check our documentation or contact support." FontSize="12" Foreground="White" Opacity="0.9" Margin="0,4,0,0" />
                            </StackPanel>

                            <Button Grid.Column="2" Content="Documentation" Background="White" Foreground="{DynamicResource PrimaryBrush}" Padding="16,8" FontWeight="Bold" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </StackPanel>

            </StackPanel>
        </Border>
    </ScrollViewer>

</UserControl>
