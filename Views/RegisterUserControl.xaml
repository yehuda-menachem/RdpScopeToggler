<UserControl x:Class="RdpScopeToggler.Views.RegisterUserControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{DynamicResource BackgroundBrushLight}"
             Foreground="{DynamicResource TextBrushLightPrimary}"
             FontFamily="Segoe UI"
             MinHeight="500">

    <Grid>
        <!-- Centered content container -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="400">
            <!-- Logo & Header -->
            <StackPanel Margin="0,0,0,48">
                <Grid HorizontalAlignment="Center" Margin="0,0,0,16">
                    <Border Width="48" Height="48" CornerRadius="8" Background="{DynamicResource PrimaryBrush}">
                        <TextBlock Text="&#xE8AF;" FontFamily="Segoe MDL2 Assets" FontSize="24"
                                   Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                </Grid>
                <TextBlock Text="Create Account" FontSize="28" FontWeight="Bold"
                           Foreground="{DynamicResource TextBrushLightPrimary}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="Join RdpScope" FontSize="13"
                           Foreground="{DynamicResource TextBrushLightSecondary}"
                           HorizontalAlignment="Center" Margin="0,4,0,0" />
            </StackPanel>

            <!-- Register Card -->
            <Border Background="{DynamicResource BackgroundBrushLight}"
                    BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                    CornerRadius="12" Padding="32" Margin="0,0,0,24"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <!-- Username Field -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Username" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,0,0,8" />
                        <Border Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="8" Height="40">
                            <TextBox x:Name="UsernameTextBox"
                                     Padding="16,0,16,0"
                                     VerticalAlignment="Stretch"
                                     VerticalContentAlignment="Center"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{DynamicResource TextBrushLightPrimary}"
                                     CaretBrush="{DynamicResource PrimaryBrush}"
                                     Style="{StaticResource ModernTextBoxStyle}"/>
                        </Border>
                        <TextBlock Text="Minimum 3 characters" FontSize="10"
                                   Foreground="{DynamicResource TextBrushLightTertiary}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Password Field -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Password" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,0,0,8" />
                        <Border Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="8" Height="40">
                            <PasswordBox x:Name="PasswordBox"
                                         Padding="16,0,16,0"
                                         VerticalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextBrushLightPrimary}"
                                         CaretBrush="{DynamicResource PrimaryBrush}"
                                         Style="{StaticResource ModernPasswordBoxStyle}"/>
                        </Border>
                        <TextBlock Text="Minimum 6 characters" FontSize="10"
                                   Foreground="{DynamicResource TextBrushLightTertiary}"
                                   Margin="0,4,0,0" />
                    </StackPanel>

                    <!-- Confirm Password Field -->
                    <StackPanel Margin="0,0,0,16">
                        <TextBlock Text="Confirm Password" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextBrushLightPrimary}" Margin="0,0,0,8" />
                        <Border Background="{DynamicResource BackgroundBrushLightSecondary}"
                                BorderThickness="1" BorderBrush="{DynamicResource BorderBrushLight}"
                                CornerRadius="8" Height="40">
                            <PasswordBox x:Name="ConfirmPasswordBox"
                                         Padding="16,0,16,0"
                                         VerticalAlignment="Stretch"
                                         VerticalContentAlignment="Center"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{DynamicResource TextBrushLightPrimary}"
                                         CaretBrush="{DynamicResource PrimaryBrush}"
                                         Style="{StaticResource ModernPasswordBoxStyle}"/>
                        </Border>
                    </StackPanel>

                    <!-- Register Button -->
                    <Button x:Name="RegisterButton"
                            Height="44" Margin="0,12,0,0"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="White"
                            FontSize="14" FontWeight="Bold"
                            Cursor="Hand"
                            Click="RegisterButton_Click"
                            Style="{StaticResource PrimaryButton}">
                        <TextBlock Text="Create Account" />
                    </Button>
                </StackPanel>
            </Border>

            <!-- Back to Login Button -->
            <Button x:Name="BackToLoginButton"
                    Height="44"
                    Cursor="Hand"
                    Click="BackToLoginButton_Click"
                    Style="{StaticResource SecondaryButton}">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="Back to Login" VerticalAlignment="Center" />
                </StackPanel>
            </Button>

            <!-- Footer -->
            <StackPanel HorizontalAlignment="Center" Margin="0,32,0,0">
                <TextBlock Text="v2.4.0 • Enterprise Edition" FontSize="11"
                           Foreground="{DynamicResource TextBrushLightTertiary}"
                           HorizontalAlignment="Center" Margin="0,0,0,8" />
                <TextBlock Text="© 2026 RdpScope. All rights reserved." FontSize="11"
                           Foreground="{DynamicResource TextBrushLightTertiary}"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </Grid>
</UserControl>
